{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist/**"],
      "dependsOn": ["^build"],
      "inputs": ["!packages/static-site/**", "**/*"]
    },
    "dev": {
      "cache": false,
      "dependsOn": ["^dev"],
      "inputs": ["!packages/static-site/**", "**/*"]
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "**/*.test.ts"]
    }
  }
}
